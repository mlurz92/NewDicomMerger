<Window x:Class="NewDicomMerger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DICOM Multi-Frame Merger"
        Height="850" Width="1200"
        MinHeight="700" MinWidth="900"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        Background="Transparent"
        Foreground="#F1F5F9"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        PreviewMouseWheel="Window_PreviewMouseWheel">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="8" GlassFrameThickness="-1" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ═══════════════ COLOR TOKENS ═══════════════ -->
        <!-- Neutral Dark Theme (Black & Gray/Slate Tones) -->
        <SolidColorBrush x:Key="Bg"            Color="#0A0A0C"/>
        <SolidColorBrush x:Key="CardBg"        Color="#121215"/>
        <SolidColorBrush x:Key="CardBorder"     Color="#202024"/>
        <SolidColorBrush x:Key="Accent1"        Color="#ECECF1"/>   <!-- Silver/Light Gray -->
        <SolidColorBrush x:Key="Accent2"        Color="#8E8E93"/>   <!-- Medium Gray -->
        <SolidColorBrush x:Key="Accent3"        Color="#3A3A3C"/>   <!-- Dark Gray -->
        <SolidColorBrush x:Key="GoldHighlight"  Color="#F4F4F5"/>   <!-- Silver Highlight -->
        <SolidColorBrush x:Key="TextPrimary"    Color="#ECEDF0"/>
        <SolidColorBrush x:Key="TextSecondary"  Color="#8E8E96"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#52525B"/>
        <SolidColorBrush x:Key="Success"        Color="#10B981"/>
        <SolidColorBrush x:Key="Error"          Color="#F43F5E"/>
        <SolidColorBrush x:Key="Surface1"       Color="#1C1C1E"/>
        <SolidColorBrush x:Key="Surface2"       Color="#2C2C2E"/>
        <SolidColorBrush x:Key="Border1"        Color="#2C2C30"/>
        <!-- Additional theme-aware tokens (Feature: app-wide theme, not just the MPR panel).
             These are mutated in code-behind by ApplyTheme(); every element bound via
             {StaticResource X} shares the same live Brush instance, so mutating .Color
             here re-renders every consumer instantly — a lightweight, real resource-based
             theme system without needing to swap whole merged ResourceDictionaries. -->
        <SolidColorBrush x:Key="BodyText"       Color="#CCCDD2"/>
        <SolidColorBrush x:Key="TextDim"        Color="#6E6E76"/>
        <SolidColorBrush x:Key="InputBg"        Color="#0A0A0D"/>

        <!-- ═══════════════ TITLE BAR BUTTONS ═══════════════ -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{Binding TextDimBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Margin="2,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C1C1E"/>
                                <Setter Property="Foreground" Value="#ECECF1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Margin="2,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C62828"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ CHECKBOX ═══════════════ -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{Binding BodyTextBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box" Width="18" Height="18" CornerRadius="4" BorderThickness="1.5"
                                    BorderBrush="#3A3A42" Background="{DynamicResource Surface1}" VerticalAlignment="Center">
                                <TextBlock x:Name="Check" Text="✓" Foreground="#ECECF1" FontSize="12"
                                           FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#ECECF1"/>
                                <Setter TargetName="Box" Property="Background" Value="#2C2C2E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#8E8E93"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ SCROLLBAR ═══════════════ -->
        <Style x:Key="DarkThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#2A2A32" CornerRadius="3" Margin="1">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#8E8E93" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#2A2A32" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource DarkThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ PRIMARY BUTTON ═══════════════ -->
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Foreground" Value="{Binding TextPrimaryBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Base background with neutral glow shadow -->
                            <Border x:Name="Bd" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource Border1}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#141416" Offset="0"/>
                                        <GradientStop Color="#18181C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect x:Name="Glow" Color="#8E8E93" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                </Border.Effect>
                            </Border>
                            <!-- Hover overlay with neutral gradient -->
                            <Border x:Name="HoverOverlay" CornerRadius="8" Opacity="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2C2C2E" Offset="0"/>
                                        <GradientStop Color="#1C1C1E" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="28,14"/>

                            <!-- Animated border lines that trace the button on hover -->
                            <Rectangle x:Name="TopLine" Height="2" VerticalAlignment="Top" HorizontalAlignment="Stretch" RadiusX="1" RadiusY="1" RenderTransformOrigin="0,0.5">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F4F4F5" Offset="0"/>
                                        <GradientStop Color="#8E8E93" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.RenderTransform><ScaleTransform ScaleX="0"/></Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle x:Name="RightLine" Width="2" HorizontalAlignment="Right" VerticalAlignment="Stretch" RadiusX="1" RadiusY="1" RenderTransformOrigin="0.5,0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#8E8E93" Offset="0"/>
                                        <GradientStop Color="#3A3A3C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.RenderTransform><ScaleTransform ScaleY="0"/></Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle x:Name="BottomLine" Height="2" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" RadiusX="1" RadiusY="1" RenderTransformOrigin="1,0.5">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A3A3C" Offset="0"/>
                                        <GradientStop Color="#ECECF1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.RenderTransform><ScaleTransform ScaleX="0"/></Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle x:Name="LeftLine" Width="2" HorizontalAlignment="Left" VerticalAlignment="Stretch" RadiusX="1" RadiusY="1" RenderTransformOrigin="0.5,1">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#ECECF1" Offset="0"/>
                                        <GradientStop Color="#F4F4F5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.RenderTransform><ScaleTransform ScaleY="0"/></Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="BlurRadius" To="22" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0.45" Duration="0:0:0.5"/>
                                        <ColorAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#4A3F20" Duration="0:0:0.3"/>

                                        <!-- Sequential line trace: Top → Right → Bottom → Left -->
                                        <DoubleAnimation Storyboard.TargetName="TopLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="RightLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.12" BeginTime="0:0:0.08">
                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="BottomLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.12" BeginTime="0:0:0.16">
                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="LeftLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.12" BeginTime="0:0:0.24">
                                            <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="BlurRadius" To="0" Duration="0:0:0.3"/>
                                        <ColorAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#27272E" Duration="0:0:0.3"/>
                                        <DoubleAnimation Storyboard.TargetName="TopLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="RightLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="BottomLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="LeftLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ GHOST BUTTON ═══════════════ -->
        <Style TargetType="Button" x:Key="GhostBtn">
            <Setter Property="Foreground" Value="{Binding TextSecondaryBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="8" Background="{DynamicResource Surface1}" BorderThickness="1" BorderBrush="{DynamicResource Border1}"/>
                            <Border x:Name="HoverOverlay" CornerRadius="8" Opacity="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2C2C2E" Offset="0"/>
                                        <GradientStop Color="#1C1C1E" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,12"/>
                            <!-- Animated underline -->
                            <Rectangle x:Name="BottomLine" Height="2" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" RadiusX="1" RadiusY="1" RenderTransformOrigin="0.5,0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A3A3C" Offset="0"/>
                                        <GradientStop Color="#ECECF1" Offset="0.5"/>
                                        <GradientStop Color="#3A3A3C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.RenderTransform><ScaleTransform ScaleX="0"/></Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="BottomLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#2C2C2E" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BottomLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#27272E" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#ECECF1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ TOOL BUTTON ═══════════════ -->
        <Style TargetType="Button" x:Key="ToolBtn">
            <Setter Property="Foreground" Value="{Binding TextSecondaryBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="6" Background="{DynamicResource Surface1}" BorderThickness="1" BorderBrush="{DynamicResource Border1}">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="BtnGlow" Color="#8E8E93" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                </Border.Effect>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="14,7"/>
                            <Rectangle x:Name="BottomLine" Height="2" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" RadiusX="1" RadiusY="1" RenderTransformOrigin="0.5,0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A3A3C" Offset="0"/>
                                        <GradientStop Color="#ECECF1" Offset="0.5"/>
                                        <GradientStop Color="#3A3A3C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.RenderTransform><ScaleTransform ScaleX="0"/></Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BottomLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="BtnGlow" Storyboard.TargetProperty="BlurRadius" To="10" Duration="0:0:0.35"/>
                                        <DoubleAnimation Storyboard.TargetName="BtnGlow" Storyboard.TargetProperty="Opacity" To="0.25" Duration="0:0:0.35"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BottomLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="BtnGlow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BtnGlow" Storyboard.TargetProperty="BlurRadius" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2C2C2E"/>
                                <Setter Property="Foreground" Value="#ECECF1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ RADIO BUTTON (Mode selector) ═══════════════ -->
        <Style TargetType="RadioButton" x:Key="ModeRadioButton">
            <Setter Property="Foreground" Value="{Binding TextSecondaryBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="6" Background="Transparent" BorderThickness="1" BorderBrush="Transparent"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,9"/>
                            <!-- Underline indicator -->
                            <Rectangle x:Name="BottomLine" Height="2" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" RadiusX="1" RadiusY="1" RenderTransformOrigin="0.5,0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A3A3C" Offset="0"/>
                                        <GradientStop Color="#ECECF1" Offset="0.5"/>
                                        <GradientStop Color="#3A3A3C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.RenderTransform><ScaleTransform ScaleX="0"/></Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F0F12"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BottomLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.5" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BottomLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2C2C2E"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A3A3C"/>
                                <Setter Property="Foreground" Value="#ECECF1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="Checked" Handler="Mode_Checked"/>
        </Style>

        <!-- ═══════════════ STAT CARD ═══════════════ -->
        <Style TargetType="Border" x:Key="StatCard">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{Binding CardBorderBrushBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Background" Value="{Binding CardBgBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Style>
    </Window.Resources>

    <!-- ═══════════════ WINDOW CONTENT ═══════════════ -->
    <Border CornerRadius="8" ClipToBounds="True" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}" Background="{DynamicResource Bg}">
        <Grid>
            <!-- Subtle ambient neutral glow in top-left corner -->
            <Ellipse Width="500" Height="500" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-200,-200,0,0" Opacity="0.04" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8E8E93" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <!-- Subtle ambient glow bottom-right -->
            <Ellipse Width="400" Height="400" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-150,-150" Opacity="0.025" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3A3A3C" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ────── Custom Title Bar ────── -->
            <Grid VerticalAlignment="Top" Height="42" Panel.ZIndex="1000">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0D0D10" Offset="0"/>
                        <GradientStop Color="#111114" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Subtle bottom separator -->
                <Border Height="1" VerticalAlignment="Bottom" Opacity="0.5" Grid.ColumnSpan="3">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#2C2C30" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="14,0,0,0">
                    <!-- Silver diamond icon -->
                    <Path Data="M 12 2 L 22 12 L 12 22 L 2 12 Z" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F4F4F5" Offset="0"/>
                                <GradientStop Color="#3A3A3C" Offset="1"/>
                            </LinearGradientBrush>
                        </Path.Fill>
                    </Path>
                    <TextBlock Text="DICOM Merger" Foreground="{DynamicResource TextDim}" FontWeight="SemiBold" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Content="—" Style="{StaticResource TitleBarButton}" Click="MinBtn_Click"/>
                    <Button Content="☐" Style="{StaticResource TitleBarButton}" Click="MaxBtn_Click" FontSize="14"/>
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButton}" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>

            <!-- ────── MAIN LAYOUT ────── -->
            <Grid Margin="40,64,40,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>    <!-- Header -->
                    <RowDefinition Height="*"/>       <!-- Content card -->
                    <RowDefinition Height="Auto"/>    <!-- Stats row -->
                    <RowDefinition Height="Auto"/>    <!-- Progress -->
                    <RowDefinition Height="Auto"/>    <!-- Action Bar -->
                    <RowDefinition Height="Auto"/>    <!-- Bottom Nav -->
                </Grid.RowDefinitions>

                <!-- ────── HEADER with gradient silver text ────── -->
                <StackPanel Grid.Row="0" Margin="0,0,0,28">
                    <Grid HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock FontSize="30" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F4F4F5" Offset="0"/>
                                        <GradientStop Color="#ECECF1" Offset="0.4"/>
                                        <GradientStop Color="#8E8E93" Offset="0.7"/>
                                        <GradientStop Color="#ECECF1" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                DICOM Multi-Frame Merger
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <!-- Subtle silver separator under the title -->
                    <Border Height="1" Margin="80,12,80,0" Opacity="0.4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#3A3A3C" Offset="0.3"/>
                                <GradientStop Color="#ECECF1" Offset="0.5"/>
                                <GradientStop Color="#3A3A3C" Offset="0.7"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <!-- ────── CONTENT CARD ────── -->
                <Border x:Name="CardBorderColor" Grid.Row="1" CornerRadius="16" ClipToBounds="True" BorderThickness="1">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#202024" Offset="0"/>
                            <GradientStop Color="#2C2C2E" Offset="0.5"/>
                            <GradientStop Color="#202024" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0A0A0C" Offset="0"/>
                            <GradientStop Color="#121215" Offset="0.5"/>
                            <GradientStop Color="#0A0A0C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Mode segmented control: docked, own row -->
                            <RowDefinition Height="*"/>     <!-- Content: DropZone / Log / Review -->
                        </Grid.RowDefinitions>

                        <!-- Bugfix: the mode toggle used to float (HorizontalAlignment=Center,
                             VerticalAlignment=Top, no Grid.Row) directly on top of this Grid's
                             other children instead of occupying its own row — once the Review
                             panel's toolbar (Alle/Keine/Scouts/Tags buttons) appeared at the same
                             vertical position, the two visually overlapped. Giving it Grid.Row="0"
                             and everything else Grid.Row="1" makes that collision structurally
                             impossible instead of just visually unlikely. -->
                        <!-- Windows 11 "SegmentedControl"-style mode switch: equal-width segments with
                             a sliding pill indicator that animates behind whichever one is selected,
                             instead of a static underline. -->
                        <Border Grid.Row="0" HorizontalAlignment="Center" Margin="0,18,0,0" CornerRadius="10" Padding="4" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0A0A0D" Offset="0"/>
                                    <GradientStop Color="#0D0D10" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid x:Name="ModeToggleGrid" Width="720">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Sliding pill (behind the RadioButtons in z-order) -->
                                <Border x:Name="ModeSlider" Grid.Column="0" CornerRadius="7" Margin="2" BorderThickness="1" RenderTransformOrigin="0,0.5" SizeChanged="ModeSlider_SizeChanged">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ModeSliderTransform" X="0"/>
                                    </Border.RenderTransform>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#3A3A3C" Offset="0"/>
                                            <GradientStop Color="#ECECF1" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#2C2C2E" Offset="0"/>
                                            <GradientStop Color="#1C1C1E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#8E8E93" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
                                    </Border.Effect>
                                </Border>
                                <RadioButton x:Name="ModeMerge" Grid.Column="0" Content="Zusammenführen" ToolTip="Führt mehrere Einzelbild-DICOM-Dateien (Single-Frame) einer Serie zu einer einzigen Multi-Frame-DICOM-Datei zusammen." GroupName="Mode" IsChecked="True" HorizontalAlignment="Stretch" Style="{StaticResource ModeRadioButton}"/>
                                <RadioButton x:Name="ModeSplit" Grid.Column="1" Content="Aufteilen" ToolTip="Teilt eine Multi-Frame-DICOM-Datei in einzelne Single-Frame-DICOM-Dateien auf." GroupName="Mode" HorizontalAlignment="Stretch" Style="{StaticResource ModeRadioButton}"/>
                                <RadioButton x:Name="ModeNifti" Grid.Column="2" Content="NIfTI Export" ToolTip="Konvertiert DICOM-Serien direkt in das NIfTI-Format (.nii.gz) für wissenschaftliche Auswertungen." GroupName="Mode" HorizontalAlignment="Stretch" Style="{StaticResource ModeRadioButton}"/>
                            </Grid>
                        </Border>

                        <!-- ────── Drop Zone ────── -->
                        <StackPanel x:Name="DropZonePanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid HorizontalAlignment="Center" Margin="0,0,0,32">
                                <!-- Outer pulsing ring -->
                                <Border x:Name="PulseRing" Width="104" Height="104" CornerRadius="26" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="1" Opacity="0.3" CacheMode="BitmapCache">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#ECECF1" Offset="0"/>
                                            <GradientStop Color="#3A3A3C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="Opacity" From="0.35" To="0.08" Duration="0:0:2.5" AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                                <!-- Second, slower counter ring for more depth -->
                                <Border Width="122" Height="122" CornerRadius="30" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="1" Opacity="0.12" BorderBrush="#ECECF1" CacheMode="BitmapCache">
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.05" To="0.18" Duration="0:0:3.4" AutoReverse="True" BeginTime="0:0:0.6">
                                                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                                <!-- Icon box -->
                                <Border Width="80" Height="80" CornerRadius="20" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="1.5">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#ECECF1" Offset="0"/>
                                            <GradientStop Color="#3A3A3C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2C2C2E" Offset="0"/>
                                            <GradientStop Color="#121215" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#8E8E93" BlurRadius="24" ShadowDepth="0" Opacity="0.35"/>
                                    </Border.Effect>
                                    <TextBlock Text="📁" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="DropZoneTitle" Text="Dateien oder Ordner hier ablegen" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource BodyText}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DropZoneSubtitle" Text="Verarbeitung erfolgt superschnell per Drag &amp; Drop" FontSize="13" Foreground="{DynamicResource TextDim}" HorizontalAlignment="Center" Margin="0,8,0,0" TextAlignment="Center"/>

                            <!-- Format pills: quick, modern visual cue for what's accepted -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                                <Border CornerRadius="12" Background="{DynamicResource Surface1}" BorderThickness="1" BorderBrush="{DynamicResource Border1}" Padding="10,4" Margin="0,0,8,0">
                                    <TextBlock Text=".dcm / .ima" FontSize="11" FontFamily="Cascadia Mono, Consolas, monospace" Foreground="{DynamicResource TextSecondary}"/>
                                </Border>
                                <Border CornerRadius="12" Background="{DynamicResource Surface1}" BorderThickness="1" BorderBrush="{DynamicResource Border1}" Padding="10,4" Margin="0,0,8,0">
                                    <TextBlock Text="ZIP-Archive" FontSize="11" FontFamily="Cascadia Mono, Consolas, monospace" Foreground="{DynamicResource TextSecondary}"/>
                                </Border>
                                <Border CornerRadius="12" Background="{DynamicResource Surface1}" BorderThickness="1" BorderBrush="{DynamicResource Border1}" Padding="10,4">
                                    <TextBlock Text="ganze Ordner" FontSize="11" FontFamily="Cascadia Mono, Consolas, monospace" Foreground="{DynamicResource TextSecondary}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- ────── Log Panel ────── -->
                        <Grid x:Name="LogPanel" Grid.Row="1" Visibility="Collapsed" Margin="4">
                            <Border CornerRadius="14" Background="{DynamicResource InputBg}" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}">
                                <TextBox x:Name="LogTextBox" IsReadOnly="True" Background="Transparent" Foreground="#A0A8B8" BorderThickness="0" Padding="24,20" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"/>
                            </Border>
                        </Grid>

                        <!-- ────── Review Panel ────── -->
                        <Grid x:Name="ReviewPanel" Grid.Row="1" Visibility="Collapsed" Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Smart Selection Tools -->
                            <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                                <Button Content="✓ Alle" ToolTip="Wählt alle geladenen Serien in der Liste aus (Ctrl+A)." Style="{StaticResource ToolBtn}" Margin="0,0,8,8" Click="SelectAll_Click"/>
                                <Button Content="✕ Keine" ToolTip="Hebt die Auswahl für alle Serien in der Liste auf (Ctrl+D)." Style="{StaticResource ToolBtn}" Margin="0,0,8,8" Click="SelectNone_Click"/>
                                <Button Content="🤖 Scouts ignorieren" ToolTip="Wählt Übersichtsserie/Localizer/Scout-Aufnahmen manuell ab (Ctrl+Shift+S)." Style="{StaticResource ToolBtn}" Margin="0,0,8,8" Click="IgnoreScouts_Click"/>
                                <Button Content="🔍 Tags" ToolTip="Öffnet den DICOM-Tag-Inspector für die aktuell gewählte Serie (Ctrl+T)." Style="{StaticResource ToolBtn}" Margin="0,0,0,8" Click="TagViewerButton_Click"/>
                            </WrapPanel>

                            <!-- Split Panel: DataGrid + Mini Viewer (2D Vorschaufenster schmaler für mehr Platz bei Sequenznamen) -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5*" MinWidth="400"/>
                                    <ColumnDefinition Width="3*" MinWidth="320"/>
                                </Grid.ColumnDefinitions>

                                <!-- DataGrid -->
                                <DataGrid x:Name="ReviewGrid" Grid.Column="0" SelectionChanged="ReviewGrid_SelectionChanged" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#08C9A84C" HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0" Foreground="{DynamicResource BodyText}" FontSize="13">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{Binding CardBgBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Setter Property="Foreground" Value="{Binding TextSecondaryBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="{Binding CardBorderBrushBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#22ECECF1"/>
                                                    <Setter Property="Foreground" Value="#ECECF1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#11ECECF1"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#22ECECF1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Wählen" Width="60">
                                            <DataGridTemplateColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                    <Setter Property="ToolTip" Value="Checkbox aktivieren/deaktivieren um Serie in die Verarbeitung einzuschließen"/>
                                                </Style>
                                            </DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" ToolTip="Serie für Verarbeitung auswählen oder abwählen" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Modality" Binding="{Binding Modality}" IsReadOnly="True" Width="62">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                    <Setter Property="ToolTip" Value="DICOM Modality (z.B. MR, CT, US, PT)"/>
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Frames" Binding="{Binding FrameCount}" IsReadOnly="True" Width="52">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                    <Setter Property="ToolTip" Value="Anzahl der Einzelbilder in dieser Serie"/>
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" IsReadOnly="True" Width="98">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                    <Setter Property="ToolTip" Value="Gibt an, ob alle Quelldateien der Serie konsistent sind oder einige ausgeschlossen wurden"/>
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="ToolTip" Value="{Binding StatusTooltip}"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasWarning}" Value="True">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Patientenname" Binding="{Binding PatientName, UpdateSourceTrigger=PropertyChanged}" Width="1.2*" MinWidth="110">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                    <Setter Property="ToolTip" Value="Patientenname aus den DICOM-Headern (Doppelklick zum Anpassen)"/>
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="ToolTip" Value="{Binding PatientName}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Sequenzname" Binding="{Binding SeriesName, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" MinWidth="130">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                    <Setter Property="ToolTip" Value="Name der Sequenz/Serie. Frühere Untersuchungen erhalten _VU, Duplikate _1, _2, etc."/>
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="ToolTip" Value="{Binding SeriesName}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                 <!-- MPR 3D Viewer -->
                                <Border Grid.Column="1" Margin="16,0,0,0" CornerRadius="10" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}" x:Name="MprBorder" PreviewMouseWheel="MprBorder_PreviewMouseWheel">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#0A0A0C" Offset="0"/>
                                            <GradientStop Color="#0A0A0C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header / Controls -->
                                        <Border CornerRadius="10,10,0,0" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource CardBorder}" x:Name="MprHeaderBorder">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#0D0D10" Offset="0"/>
                                                    <GradientStop Color="#111114" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="MprTitleText" Text="2D-Vorschau" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center">
                                                    <TextBlock.Foreground>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#ECECF1" Offset="0"/>
                                                            <GradientStop Color="#3A3A3C" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </TextBlock.Foreground>
                                                </TextBlock>

                                                <!-- Preset buttons directly in Header -->
                                            </Grid>
                                        </Border>

                                        <!-- 2D View Grid -->
                                        <Grid Grid.Row="1" Margin="8">
                                            <!-- Empty indicator -->
                                            <TextBlock x:Name="PreviewEmptyText" Text="Serie auswählen" Foreground="#2A2A32" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>

                                            <!-- Loading Text -->
                                            <TextBlock x:Name="PreviewLoadingText" Text="Lade 2D-Volumen..." Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

                                            <!-- View 2D (Maximized) -->
                                            <Border x:Name="ViewAxial" BorderThickness="0.5" BorderBrush="{DynamicResource CardBorder}" Margin="3" CornerRadius="4" Background="#050508">
                                                <Grid>
                                                    <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="Linear" SnapsToDevicePixels="True"/>
                                                    <TextBlock x:Name="SliceIndexText" Text="2D-ANSICHT" Foreground="#44CCCDD2" FontSize="9" FontWeight="Bold" Margin="6,4" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                    <Border VerticalAlignment="Bottom" Background="#88000000" Padding="4,2" x:Name="PreviewControls" Visibility="Collapsed">
                                                        <Slider x:Name="PreviewSlider" Minimum="0" Maximum="0" ValueChanged="PreviewSlider_ValueChanged" Height="14" IsSnapToTickEnabled="True" TickFrequency="1" Foreground="{DynamicResource Accent2}"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ────── STATS ROW ────── -->
                <WrapPanel Grid.Row="2" x:Name="StatsRow" Visibility="Collapsed" Margin="0,18,0,0" HorizontalAlignment="Center">
                    <Border Style="{StaticResource StatCard}" Margin="0,0,6,0" MinWidth="128">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📥" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="GELADEN" FontSize="10" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Height="2" Width="24" HorizontalAlignment="Left" CornerRadius="1" Margin="0,6,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A3A3C" Offset="0"/>
                                        <GradientStop Color="#ECECF1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="StatLoaded" Text="—" FontSize="26" FontWeight="Bold" Margin="0,4,0,0">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A3A3C" Offset="0"/>
                                        <GradientStop Color="#ECECF1" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="3,0,3,0" MinWidth="128">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗂" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="SERIEN" FontSize="10" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Height="2" Width="24" HorizontalAlignment="Left" CornerRadius="1" Margin="0,6,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#ECECF1" Offset="0"/>
                                        <GradientStop Color="#F4F4F5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="StatSeries" Text="—" FontSize="26" FontWeight="Bold" Margin="0,4,0,0">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#ECECF1" Offset="0"/>
                                        <GradientStop Color="#F4F4F5" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="3,0,3,0" MinWidth="128">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✅" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="ERSTELLT" FontSize="10" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Height="2" Width="24" HorizontalAlignment="Left" Background="{DynamicResource Success}" CornerRadius="1" Margin="0,6,0,0"/>
                            <TextBlock x:Name="StatCreated" Text="—" FontSize="26" Foreground="{DynamicResource Success}" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="6,0,0,0" MinWidth="128">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="FEHLER" FontSize="10" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Height="2" Width="24" HorizontalAlignment="Left" Background="{DynamicResource Error}" CornerRadius="1" Margin="0,6,0,0"/>
                            <TextBlock x:Name="StatErrors" Text="—" FontSize="26" Foreground="{DynamicResource Error}" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- ────── DASHBOARD / PROGRESS ────── -->
                <Grid Grid.Row="3" Margin="0,18,0,0" x:Name="DashboardPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Bugfix (found alongside the mode-toggle overlap bug — same root cause: no
                         column separation between two absolutely-aligned siblings): a long status
                         message (e.g. a long file/folder name) could grow the left StackPanel far
                         enough right to run straight into the right-aligned ETA text with nothing
                         to stop it. Explicit columns plus trimming make that structurally impossible. -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock x:Name="DashboardStatusText" Text="Starte Verarbeitung…" FontSize="14" Foreground="{DynamicResource BodyText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            <TextBlock x:Name="DashboardSpeedText" Text=" (0 Serien/s)" FontSize="12" Foreground="#ECECF1" Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                        </StackPanel>
                        <TextBlock x:Name="DashboardEtaText" Grid.Column="1" Text="Restzeit: Berechne..." FontSize="12" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12,0,0,0"/>
                    </Grid>
                    <!-- Progress bar with silver gradient fill -->
                    <Border Grid.Row="1" CornerRadius="5" Height="10" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0D0D10" Offset="0"/>
                                <GradientStop Color="#111114" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid ClipToBounds="True">
                            <Border x:Name="DashboardProgressFill" HorizontalAlignment="Left" Width="0" CornerRadius="5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A3A3C" Offset="0"/>
                                        <GradientStop Color="#8E8E93" Offset="0.5"/>
                                        <GradientStop Color="#ECECF1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ────── ACTION BAR ────── -->
                <Border x:Name="ActionBar" Grid.Row="4" Visibility="Collapsed" CornerRadius="12" Padding="16,14" BorderThickness="1" BorderBrush="{DynamicResource Border1}" Background="#CC111114" Margin="0,18,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Row 0: Checkboxes mit erklärenden Hover Tooltips -->
                        <WrapPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                            <CheckBox x:Name="CheckTurbo" Content="🚀 Turbo" IsChecked="True" ToolTip="Multi-Core Parallelausführung für maximale Verarbeitungsgeschwindigkeit." Margin="0,0,20,8"/>
                            <CheckBox x:Name="CheckAnonymize" Content="Anonym" ToolTip="Anonymisiert Klarnamen, IDs und persönliche Daten in allen DICOM-Headern." Margin="0,0,20,8"/>
                            <CheckBox x:Name="CheckCompressDicom" Content="🤐 DICOM JPEG Lossless" ToolTip="Verlustfreie DICOM JPEG-Lossless-Kompression für deutlich reduzierte Dateigröße." Margin="0,0,20,8"/>
                            <CheckBox x:Name="CheckZipOutput" Content="📦 ZIP" ToolTip="Packt die konvertierten Dateien mit portablem 7-Zip in Stufe 9-Ultra zusammen als eine nach dem Patientennamen benannte .zip Datei." Margin="0,0,20,8"/>
                            <CheckBox x:Name="CheckExportNiftiDirect" Content="🌐 NIfTI" ToolTip="Erstellt zusätzlich zum DICOM-Ergebnis NIfTI-Exportdateien (.nii.gz)." Margin="0,0,20,8"/>
                            <CheckBox x:Name="CheckBatchReport" Content="📊 Bericht (CSV/JSON)" Margin="0,0,20,8" ToolTip="Schreibt einen ausführlichen Batch-Bericht (Erfolg/Fehler je Serie) als CSV und JSON in den Ausgabeordner."/>
                            <CheckBox x:Name="CheckCreateDicomdir" Content="💿 DICOMDIR" Margin="0,0,20,8" ToolTip="Erstellt eine standardkonforme DICOMDIR-Indexdatei im Ausgabeordner (für CD/USB-Export)."/>
                            <WrapPanel x:Name="NiftiSettingsPanel" Visibility="Collapsed" VerticalAlignment="Center">
                                <CheckBox x:Name="CheckCompressGz" Content=".gz" IsChecked="True" ToolTip="Komprimiert NIfTI-Ausgaben als .nii.gz" Margin="0,0,12,8"/>
                                <CheckBox x:Name="CheckBidsJson" Content="BIDS" ToolTip="Erzeugt BIDS-konforme Sidecar-JSON-Metadaten für NIfTI-Dateien." Margin="0,0,12,8"/>
                                <TextBox x:Name="TxtNiftiFormat" Text="%n-%p" ToolTip="Formatierungsstring für NIfTI Dateinamen (z.B. %n-%p)" Width="60" Background="{DynamicResource InputBg}" Foreground="{DynamicResource BodyText}" BorderThickness="1" BorderBrush="{DynamicResource Border1}" Padding="4,2" Margin="0,0,8,8"/>
                            </WrapPanel>
                        </WrapPanel>

                        <!-- Row 1: Output Folder & Name Template -->
                        <WrapPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Ausgabe:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox x:Name="TxtOutputDir" ToolTip="Zielverzeichnis für die verarbeiteten Ausgabedateien" Width="260" Background="{DynamicResource InputBg}" Foreground="{DynamicResource BodyText}" BorderThickness="1" BorderBrush="{DynamicResource Border1}" Padding="6,4" IsReadOnly="True" Margin="0,0,6,8"/>
                            <Button Content="📂" ToolTip="Ausgabeordner ändern" Style="{StaticResource ToolBtn}" Click="ChangeOutputDir_Click" Margin="0,0,24,8"/>
                            
                            <TextBlock Text="Name:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <ComboBox x:Name="TxtFilenameTemplate" ToolTip="Muster für die Dateibenennung. Verfügbare Platzhalter: {Patient}, {Serie}, {Datum}, {Modalität}, {StudyID}, {Frames}, {Accession}." Width="190" Background="{DynamicResource InputBg}" Foreground="{DynamicResource BodyText}" BorderThickness="1" BorderBrush="{DynamicResource Border1}" Padding="4,2" Margin="0,0,0,8" IsEditable="True" TextBoxBase.TextChanged="TxtFilenameTemplate_TextChanged" Text="{}{Patient}-{Serie}-{Datum}">
                                <ComboBoxItem Content="{}{Patient}-{Serie}-{Datum}"/>
                                <ComboBoxItem Content="{}{Patient}-{Serie}"/>
                                <ComboBoxItem Content="{}{Serie}_{Modality}"/>
                                <ComboBoxItem Content="{}{Patient}_{Datum}"/>
                            </ComboBox>
                        </WrapPanel>

                        <!-- Big Start Button -->
                        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,8">
                            <Button x:Name="StartProcessButton" Content="▶ Starten" ToolTip="Startet die Konvertierung aller ausgewählten Serien mit den gewählten Optionen (Ctrl+Enter)" Style="{StaticResource PrimaryBtn}" Visibility="Collapsed" Click="StartProcessButton_Click" Padding="20,8" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ────── BOTTOM NAV ────── -->
                <Grid Grid.Row="5" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="CopyButton" Content="📋 Log kopieren" ToolTip="Kopiert den gesamten bisherigen Protokolltext in die Zwischenablage" Style="{StaticResource GhostBtn}" Margin="0,0,10,0" Click="CopyButton_Click" Visibility="Collapsed"/>
                        <Button x:Name="ClearButton" Content="↺ Zurücksetzen" ToolTip="Setzt die Anwendung zurück und entfernt alle geladenen Serien (F5)" Style="{StaticResource GhostBtn}" Margin="0,0,10,0" Click="ClearButton_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelButton" Content="✕ Abbrechen" ToolTip="Bricht den laufenden Such- oder Konvertierungsvorgang sofort ab (Esc)" Style="{StaticResource GhostBtn}" Margin="0,0,10,0" Visibility="Collapsed" Click="CancelButton_Click"/>
                        <Button x:Name="BrowseButton" Content="📂 Ordner durchsuchen" ToolTip="Öffnet einen Ordnerdialog zum Auswählen von DICOM-Ordnern (Ctrl+O)" Style="{StaticResource PrimaryBtn}" Click="BrowseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ════════ FEATURE 3: COMPLETION PANEL ════════ -->
            <Grid x:Name="CompletionPanel" Visibility="Collapsed" Panel.ZIndex="500">
                <Border Background="#E8080A0C" CornerRadius="8"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Animated Ring -->
                    <Grid Width="104" Height="104" Margin="0,0,0,28">
                        <Ellipse Stroke="{DynamicResource CardBorder}" StrokeThickness="5" Width="80" Height="80"/>
                        <Ellipse x:Name="CompletionRingProgress" StrokeThickness="5" Width="80" Height="80"
                                 StrokeDashCap="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#ECECF1" Offset="0"/>
                                    <GradientStop Color="#8E8E93" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#ECECF1" BlurRadius="18" ShadowDepth="0" Opacity="0.5"/>
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <TextBlock x:Name="CompletionCheckmark" Text="✓" Foreground="#ECECF1" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Grid>
                    <TextBlock Text="Verarbeitung abgeschlossen" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <!-- Stats Grid, in its own card for visual grouping -->
                    <Border CornerRadius="14" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}" Background="{DynamicResource CardBg}" Padding="28,20" Margin="0,0,0,28">
                        <UniformGrid Columns="4" Width="480">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🗂 SERIEN" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CompletionSeriesText" Text="0" Foreground="#ECECF1" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="✅ ERSTELLT" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CompletionCreatedText" Text="0" Foreground="#10B981" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⚠ FEHLER" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CompletionErrorsText" Text="0" Foreground="#F43F5E" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⏱ DAUER" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="CompletionTimeText" Text="0s" Foreground="{DynamicResource TextSecondary}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </UniformGrid>
                    </Border>
                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="📂 Ausgabe öffnen" Style="{StaticResource PrimaryBtn}" Margin="0,0,12,0" Click="OpenOutputFolder_Click"/>
                        <Button Content="↺ Nochmal" Style="{StaticResource GhostBtn}" Click="CompletionReset_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ════════ FEATURE 5: TAG VIEWER OVERLAY ════════ -->
            <Grid x:Name="TagViewerPanel" Visibility="Collapsed" Panel.ZIndex="1500">
                <Border Background="#F0080A0C" CornerRadius="8" MouseDown="CloseTagViewer_Click"/>
                <Border Margin="60,60" CornerRadius="14" BorderThickness="1" BorderBrush="{DynamicResource Border1}" MaxWidth="900" MaxHeight="600" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0D0D10" Offset="0"/>
                            <GradientStop Color="#111114" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Header -->
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="DICOM Tag Inspector" Foreground="#ECECF1" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="✕" Style="{StaticResource ToolBtn}" HorizontalAlignment="Right" Click="CloseTagViewer_Click"/>
                        </Grid>
                        <!-- Search -->
                        <TextBox x:Name="TagSearchBox" Grid.Row="1" Background="{DynamicResource Surface1}" Foreground="{DynamicResource BodyText}" BorderThickness="1" BorderBrush="{DynamicResource Border1}" Padding="10,8" Margin="0,0,0,12" FontSize="13" TextChanged="TagSearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Tag" Value="🔍 Tag, Name oder Wert suchen..."/>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <!-- Tag DataGrid -->
                        <DataGrid x:Name="TagGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#06ECECF1" HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0" Foreground="{DynamicResource BodyText}" FontSize="12" FontFamily="Cascadia Mono, Consolas, monospace">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{Binding CardBgBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <Setter Property="Foreground" Value="{Binding TextSecondaryBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tag" Binding="{Binding TagHex}" Width="120"/>
                                <!-- Bugfix (same pattern as the ReviewGrid name columns): long DICOM tag
                                     names (e.g. "SharedFunctionalGroupsSequence") were hard-clipped with
                                     no ellipsis and no way to read the rest. -->
                                <DataGridTextColumn Header="Name" Binding="{Binding TagName}" Width="200">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="ToolTip" Value="{Binding TagName}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="VR" Binding="{Binding VR}" Width="50"/>
                                <DataGridTextColumn Header="Wert" Binding="{Binding Value}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="ToolTip" Value="{Binding Value}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ════════ FEATURE 7: SHORTCUT OVERLAY ════════ -->
            <Grid x:Name="ShortcutOverlay" Visibility="Collapsed" Panel.ZIndex="2500" MouseDown="CloseShortcutOverlay_Click">
                <Border Background="#E8080A0C" CornerRadius="8"/>
                <Border CornerRadius="14" BorderThickness="1" BorderBrush="{DynamicResource Border1}" Padding="40,32" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="420">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0D0D10" Offset="0"/>
                            <GradientStop Color="#111114" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#8E8E93" BlurRadius="30" Opacity="0.15" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Tastenkürzel" Foreground="#ECECF1" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <Border Height="1" Background="#1C1C22" Margin="0,0,0,16"/>
                        <!-- Shortcut list -->
                        <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl + O" Foreground="#ECECF1" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Ordner öffnen" Foreground="{DynamicResource BodyText}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl + Enter" Foreground="#ECECF1" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Verarbeitung starten" Foreground="{DynamicResource BodyText}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl + A" Foreground="#ECECF1" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Alle Serien auswählen" Foreground="{DynamicResource BodyText}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl + D" Foreground="#ECECF1" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Auswahl aufheben" Foreground="{DynamicResource BodyText}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl + Shift + S" Foreground="#ECECF1" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Scouts ignorieren" Foreground="{DynamicResource BodyText}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ctrl + T" Foreground="#ECECF1" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="DICOM Tag Inspector" Foreground="{DynamicResource BodyText}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="F5" Foreground="#ECECF1" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Zurücksetzen" Foreground="{DynamicResource BodyText}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Escape" Foreground="#ECECF1" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Overlay schließen / Abbrechen" Foreground="{DynamicResource BodyText}" FontSize="13"/>
                        </Grid>
                        <Border Height="1" Background="#1C1C22" Margin="0,12,0,12"/>
                        <TextBlock Text="DICOM Vorschau: Mausrad = Schichten scrollen" Foreground="{DynamicResource TextDim}" FontSize="11" HorizontalAlignment="Center"/>
                        <Border Height="1" Background="#1C1C22" Margin="0,12,0,8"/>
                        <TextBlock Text="F1 zum Schließen" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ────── TOAST NOTIFICATION ────── -->
            <Border x:Name="ToastPanel" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-80" CornerRadius="10" Padding="24,14" Panel.ZIndex="2000" Opacity="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#065F46" Offset="0"/>
                        <GradientStop Color="#047857" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#10B981" BlurRadius="24" Opacity="0.35" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✓" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToastText" Text="Vorgang erfolgreich!" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <!-- ════════ GLOBAL DRAG OVERLAY ════════ -->
            <Grid x:Name="GlobalDragOverlay" Visibility="Collapsed" Panel.ZIndex="3000">
                <Border Background="#E8080A0C" CornerRadius="8"/>
                <Border BorderThickness="3" CornerRadius="20" Margin="40" Background="#11121215">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#ECECF1" Offset="0"/>
                            <GradientStop Color="#3A3A3C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📁" FontSize="60" HorizontalAlignment="Center"/>
                        <TextBlock Text="DICOMs hier ablegen" Foreground="#ECECF1" FontSize="36" FontWeight="Bold" Margin="0,20,0,0"/>
                        <TextBlock Text="Wird sofort analysiert" Foreground="{DynamicResource BodyText}" FontSize="18" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
